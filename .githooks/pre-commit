#!/bin/bash
# Pre-commit hook for ralph-wiggum-plugin.
#
# Two gates, in order:
#   1. Shell lint (shellcheck + shfmt) on staged *.sh files, if any.
#   2. Full bats test suite — runs on EVERY commit, regardless of what
#      was staged. Per AGENTS.md, a change is not complete until all
#      tests pass. Tests are fast (< 10 s) and shell-script changes can
#      ripple through shared helpers, so we run the whole suite rather
#      than picking which tests to skip.
#
# Emergency bypass: `git commit --no-verify` — but document why in the
# commit message if you use it.

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
staged_sh_files=$(git diff --cached --name-only --diff-filter=ACM -- '*.sh' || true)
errors=0

# -----------------------------------------------------------------------------
# Shell lint — only when *.sh files are staged
# -----------------------------------------------------------------------------

if [[ -n "$staged_sh_files" ]]; then
  if command -v shellcheck >/dev/null 2>&1; then
    echo "Running shellcheck..."
    for f in $staged_sh_files; do
      if ! shellcheck "$f"; then
        errors=1
      fi
    done
  else
    echo "⚠️  shellcheck not found — skipping (brew install shellcheck)" >&2
  fi

  if command -v shfmt >/dev/null 2>&1; then
    echo "Running shfmt..."
    for f in $staged_sh_files; do
      if ! shfmt -i 2 -ci -d "$f" >/dev/null 2>&1; then
        echo "shfmt: $f needs formatting (run: shfmt -i 2 -ci -w $f)"
        errors=1
      fi
    done
  else
    echo "⚠️  shfmt not found — skipping (brew install shfmt)" >&2
  fi

  if [[ "$errors" -ne 0 ]]; then
    echo ""
    echo "Shell lint failed. Fix issues above or bypass with --no-verify."
    exit 1
  fi
fi

# -----------------------------------------------------------------------------
# Test gate — runs on EVERY commit (0.3.4)
# -----------------------------------------------------------------------------

if ! command -v bats >/dev/null 2>&1; then
  echo "❌ bats not found — cannot verify tests (brew install bats-core)" >&2
  echo "   Commits that genuinely cannot run the test gate must use" >&2
  echo "   --no-verify explicitly with justification in the message." >&2
  exit 1
fi

if ! compgen -G "$repo_root/tests/*.bats" >/dev/null 2>&1; then
  # No bats files in the tree — nothing to verify, allow.
  exit 0
fi

echo "Running bats tests/ ..."
# PATH prefix forces bash to resolve to /bin/bash (macOS system 3.2) so the
# pre-commit environment matches the portability floor the project targets.
# Homebrew bash 5.x is available on most developer machines but is not the
# version that ships out of the box — catching bash-3.2 regressions at
# commit time is cheaper than catching them in a ralph loop.
if ! PATH="/bin:$PATH" bats "$repo_root"/tests/*.bats; then
  echo ""
  echo "Pre-commit tests failed. Fix before committing (or --no-verify at your own risk)."
  exit 1
fi
